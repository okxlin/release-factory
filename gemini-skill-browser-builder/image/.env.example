CONTAINER_NAME=gemini-skill-browser
APP_IMAGE_NAME=gemini-skill-browser:local
APP_DATA_ROOT=./data
PANEL_APP_PORT_HTTPS=16901
DAEMON_PUBLIC_PORT=40225
HTTP_PWD=change-me
LAUNCH_URL=https://gemini.google.com/
GEMINI_SKILL_REPO=https://github.com/WJZ-P/gemini-skill.git
GEMINI_SKILL_REF=main
NODE_MAJOR=20
SHM_SIZE=1gb
BROWSER_DEBUG_PORT=40821
BROWSER_HEADLESS=false
BROWSER_USER_DATA_DIR=/data/browser-profile
BROWSER_PROTOCOL_TIMEOUT=180000
DAEMON_PORT=40225
DAEMON_TTL_MS=1800000
OUTPUT_DIR=/data/output
APP_ARGS=--remote-debugging-port=40821 --remote-debugging-address=0.0.0.0
