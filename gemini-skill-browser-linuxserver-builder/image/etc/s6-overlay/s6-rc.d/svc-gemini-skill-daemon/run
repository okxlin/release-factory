#!/usr/bin/with-contenv bash
set -euo pipefail

mkdir -p "${OUTPUT_DIR:-/output}" "${BROWSER_USER_DATA_DIR:-/config/browser-profile}"
chown -R abc:abc "${OUTPUT_DIR:-/output}" "${BROWSER_USER_DATA_DIR:-/config/browser-profile}" /opt/gemini-skill || true

exec s6-setuidgid abc /usr/bin/node /opt/gemini-skill/src/daemon/server.js
